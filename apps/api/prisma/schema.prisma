generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  apiKey        String         @unique
  createdAt     DateTime       @default(now())
  ownedWallets  Wallet[]       @relation("WalletOwner")
  ownedWalletGroups WalletGroup[] @relation("WalletGroupOwner")
  walletAccesses WalletAccess[]
}

model WalletGroup {
  id           String   @id @default(uuid())
  name         String   @default("Wallet Group")
  address      String   @unique
  encryptedKey String?
  lastSyncBlock Int     @default(0)
  ownerId      String?
  owner        User?    @relation("WalletGroupOwner", fields: [ownerId], references: [id])
  wallets      Wallet[]
  createdAt    DateTime @default(now())
}

model Wallet {
  id             String         @id @default(uuid())
  name           String         @default("Default Wallet")
  nameNormalized String?
  walletGroupId  String
  walletGroup    WalletGroup    @relation(fields: [walletGroupId], references: [id])
  ownerId        String?
  owner          User?          @relation("WalletOwner", fields: [ownerId], references: [id])
  accesses       WalletAccess[]
  assetBalances  WalletAssetBalance[]
  transactions   Transaction[]
  createdAt      DateTime       @default(now())

  @@unique([walletGroupId, nameNormalized])
}

model WalletAccess {
  id        String   @id @default(uuid())
  walletId  String
  wallet    Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([walletId, userId])
}

model Transaction {
  id            String    @id @default(uuid())
  walletId      String
  wallet        Wallet    @relation(fields: [walletId], references: [id])
  type          TxType
  assetType     AssetType @default(NATIVE)
  assetSymbol   String    @default("ETH")
  tokenAddress  String?
  tokenDecimals Int?
  to            String?
  from          String?
  amount        String
  txHash        String?
  nonce         Int?
  gasPrice      String?
  lockedAmount  String    @default("0")
  status        TxStatus  @default(PENDING)
  createdAt     DateTime  @default(now())

  // Prevents duplicate deposit records from concurrent scans.
  // txHash being nullable means Postgres won't enforce this for internal
  // transfers (txHash=null), which is intentional.
  @@unique([walletId, txHash, assetType])
}

// Single-chain (Sepolia) asset registry.
// contractAddress uses "native" as a sentinel for ETH so the unique
// constraint works without nullable-NULL gymnastics.
model Asset {
  id              String             @id @default(uuid())
  type            AssetType          @default(NATIVE)
  symbol          String
  decimals        Int
  contractAddress String             @unique
  balances        WalletAssetBalance[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model WalletAssetBalance {
  id         String   @id @default(uuid())
  walletId   String
  wallet     Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  balance    String   @default("0")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([walletId, assetId])
}

enum TxType {
  DEPOSIT
  WITHDRAWAL
  CONTRACT
  INTERNAL
}

enum TxStatus {
  PENDING
  BROADCASTING
  CONFIRMED
  FAILED
}

enum AssetType {
  NATIVE
  ERC20
}
